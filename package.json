{
  "name": "luagraph",
  "version": "0.1.0",
  "description": "LuaGraph TypeScript CLI skeleton.",
  "bin": {
    "luagraph": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-web-assets.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "latest",
    "echarts": "^6.1.0",
    "kuzu": "^0.11.3",
    "tree-sitter": "^0.20.6",
    "tree-sitter-lua": "^2.1.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vite-plus": "latest",
    "vitest": "latest"
  },
  "packageManager": "pnpm@11.1.3"
}
